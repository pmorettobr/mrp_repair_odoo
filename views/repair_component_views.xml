<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form do componente -->
    <record id="view_repair_cylinder_component_form" model="ir.ui.view">
        <field name="name">repair.cylinder.component.form</field>
        <field name="model">repair.cylinder.component</field>
        <field name="arch" type="xml">
            <form string="Componente do Cilindro">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nome do componente"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="repair_id" string="OS" readonly="1"/>
                            <field name="component_type" string="Tipo"/>
                        </group>
                        <group>
                            <field name="component_status" string="Status" widget="badge"
                                   decoration-success="component_status == 'done'"
                                   decoration-warning="component_status == 'in_progress'"
                                   decoration-muted="component_status == 'pending'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Processos de Serviço" name="processes">
                            <field name="process_ids">
                                <tree editable="bottom"
                                      decoration-success="status == 'done'"
                                      decoration-warning="status == 'in_progress'"
                                      decoration-danger="status == 'deviation'"
                                      decoration-muted="status == 'waiting'">
                                    <field name="sequence" widget="handle"/>
                                    <!-- Campos de controle invisíveis -->
                                    <field name="component_id" invisible="1" force_save="1"/>
                                    <field name="component_type_filter" invisible="1"/>
                                    <!-- Colunas principais - SEMPRE visíveis -->
                                    <field name="sub_component_id" string="Sub-componente"
                                           options="{'no_create': False}"/>
                                    <field name="service_type" string="Serviço" required="1"/>
                                    <field name="workcenter_id" string="Máquina"
                                           options="{'no_create': True}"/>
                                    <field name="status" string="Status" widget="badge"
                                           decoration-success="status == 'done'"
                                           decoration-warning="status == 'in_progress'"
                                           decoration-danger="status == 'deviation'"
                                           decoration-muted="status == 'waiting'"/>
                                    <!-- Colunas secundárias - opcionais -->
                                    <field name="department" string="Setor" optional="hide"/>
                                    <field name="time_start" string="Início"
                                           widget="datetime" optional="show"/>
                                    <field name="time_end" string="Fim"
                                           widget="datetime" optional="show"/>
                                    <field name="duration_hours" string="Horas"
                                           readonly="1" optional="show"/>
                                    <field name="has_deviation" string="Desvio?"
                                           widget="toggle_button" optional="hide"/>
                                    <field name="notes" string="Observação" optional="hide"/>
                                    <!-- Botões de ação -->
                                    <button name="action_start" type="object"
                                            icon="fa-play" class="btn-sm btn-warning"
                                            attrs="{'invisible': [('status', 'not in', ['waiting', 'deviation'])]}"/>
                                    <button name="action_done" type="object"
                                            icon="fa-check" class="btn-sm btn-success"
                                            attrs="{'invisible': [('status', '!=', 'in_progress')]}"/>
                                    <button name="action_set_deviation" type="object"
                                            icon="fa-exclamation-triangle" class="btn-sm btn-danger"
                                            attrs="{'invisible': [('status', 'in', ['waiting', 'done'])]}"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Observações">
                            <field name="notes"
                                   placeholder="Observações gerais sobre este componente..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree dos componentes -->
    <record id="view_repair_cylinder_component_tree" model="ir.ui.view">
        <field name="name">repair.cylinder.component.tree</field>
        <field name="model">repair.cylinder.component</field>
        <field name="arch" type="xml">
            <tree string="Componentes"
                  decoration-success="component_status == 'done'"
                  decoration-warning="component_status == 'in_progress'">
                <field name="repair_id" string="OS"/>
                <field name="component_type" string="Tipo"/>
                <field name="name" string="Componente"/>
                <field name="component_status" string="Status" widget="badge"
                       decoration-success="component_status == 'done'"
                       decoration-warning="component_status == 'in_progress'"
                       decoration-muted="component_status == 'pending'"/>
            </tree>
        </field>
    </record>

</odoo>
