<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         CATÁLOGO DE SUB-COMPONENTES
         Configuração → cadastrar partes de cada tipo de componente
    ═══════════════════════════════════════════════════════════════════ -->

    <record id="view_repair_sub_component_tree" model="ir.ui.view">
        <field name="name">repair.sub.component.tree</field>
        <field name="model">repair.sub.component</field>
        <field name="arch" type="xml">
            <tree string="Sub-componentes" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="component_type" string="Componente Pai"/>
                <field name="name" string="Sub-componente"/>
                <field name="notes" string="Observação"/>
                <field name="active" widget="toggle_button"/>
            </tree>
        </field>
    </record>

    <record id="view_repair_sub_component_search" model="ir.ui.view">
        <field name="name">repair.sub.component.search</field>
        <field name="model">repair.sub.component</field>
        <field name="arch" type="xml">
            <search string="Sub-componentes">
                <field name="name"/>
                <field name="component_type"/>
                <group expand="1" string="Agrupar por">
                    <filter name="group_type" string="Componente Pai"
                            context="{'group_by': 'component_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_repair_sub_component" model="ir.actions.act_window">
        <field name="name">Catálogo de Sub-componentes</field>
        <field name="res_model">repair.sub.component</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_repair_sub_component_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nenhum sub-componente cadastrado
            </p>
            <p>
                Cadastre aqui as partes de cada componente.<br/>
                Ex: <b>Camisa</b> → Êmbolo, Haste Interna, Anel de Vedação, Flange...
            </p>
        </field>
    </record>

    <!-- Menu de Configuração -->
    <menuitem id="menu_repair_os_config"
              name="Configuração"
              parent="menu_repair_os_root"
              sequence="90"/>

    <menuitem id="menu_repair_sub_components"
              name="Sub-componentes"
              parent="menu_repair_os_config"
              action="action_repair_sub_component"
              sequence="10"/>

</odoo>
