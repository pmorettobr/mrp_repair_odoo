<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         TELA DE CONSULTA DE STATUS
         Pivot e Kanban para acompanhamento visual do andamento
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- Kanban por Status -->
    <record id="view_repair_component_process_kanban" model="ir.ui.view">
        <field name="name">repair.component.process.kanban</field>
        <field name="model">repair.component.process</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" class="o_kanban_small_column">
                <field name="status"/>
                <field name="repair_id"/>
                <field name="component_id"/>
                <field name="service_name"/>
                <field name="workcenter_id"/>
                <field name="machine_code"/>
                <field name="duration_hours"/>
                <field name="has_deviation"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click
                            #{record.has_deviation.raw_value ? 'border-danger' : ''}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="repair_id"/>
                                    </strong>
                                </div>
                                <span t-if="record.has_deviation.raw_value"
                                      class="badge badge-danger">Desvio</span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><b>Componente: </b><field name="component_id"/></div>
                                <div><b>Serviço: </b><field name="service_name"/></div>
                                <div><b>Máquina: </b>
                                    <field name="workcenter_id"/>
                                    <span t-if="record.machine_code.raw_value">
                                        (<field name="machine_code"/>)
                                    </span>
                                </div>
                                <div t-if="record.duration_hours.raw_value">
                                    <b>Horas: </b><field name="duration_hours"/> h
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Pivot para análise de tempos -->
    <record id="view_repair_component_process_pivot" model="ir.ui.view">
        <field name="name">repair.component.process.pivot</field>
        <field name="model">repair.component.process</field>
        <field name="arch" type="xml">
            <pivot string="Análise de Processos">
                <field name="repair_id" type="row"/>
                <field name="workcenter_id" type="col"/>
                <field name="duration_hours" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Action: Tela de Consulta de Status (todas as views) -->
    <record id="action_repair_status_console" model="ir.actions.act_window">
        <field name="name">Consulta de Status</field>
        <field name="res_model">repair.component.process</field>
        <field name="view_mode">tree,kanban,pivot,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree',   'view_id': ref('view_repair_component_process_tree')}),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_repair_component_process_kanban')}),
            (0, 0, {'view_mode': 'pivot',  'view_id': ref('view_repair_component_process_pivot')}),
            (0, 0, {'view_mode': 'form',   'view_id': ref('view_repair_component_process_form')})]"/>
        <field name="search_view_id" ref="view_repair_component_process_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nenhum processo encontrado</p>
        </field>
    </record>

</odoo>
