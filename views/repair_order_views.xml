<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         TELA 1 — PROGRAMAÇÃO DAS ORDENS DE SERVIÇO
         Lista geral: OS | Cliente | Equipamento | Prazo | Progresso
    ═══════════════════════════════════════════════════════════════════ -->

    <!-- Tree/List view da OS -->
    <record id="view_repair_order_os_tree" model="ir.ui.view">
        <field name="name">repair.order.os.tree</field>
        <field name="model">repair.order</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <tree string="Ordens de Serviço" decoration-success="os_state == 'done'"
                  decoration-warning="os_state == 'in_progress'"
                  decoration-muted="os_state == 'cancel'">
                <field name="name" string="OS"/>
                <field name="partner_id" string="Cliente"/>
                <field name="equipment_description" string="Descrição do Equipamento"/>
                <field name="deadline_date" string="Prazo"
                       decoration-danger="is_overdue"/>
                <field name="os_state" string="Estado" widget="badge"
                       decoration-success="os_state == 'done'"
                       decoration-warning="os_state == 'in_progress'"
                       decoration-info="os_state == 'confirmed'"
                       decoration-muted="os_state == 'cancel'"/>
                <field name="progress_percent" string="Progresso" widget="progressbar"/>
                <field name="total_components" string="Processos"/>
                <field name="components_done" string="Concluídos"/>
                <field name="components_in_progress" string="Em Andamento"/>
                <field name="is_overdue" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form view estendido da OS -->
    <record id="view_repair_order_os_form" model="ir.ui.view">
        <field name="name">repair.order.os.form</field>
        <field name="model">repair.order</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Ordem de Serviço">
                <header>
                    <button name="action_confirm_os" string="Confirmar OS"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('os_state', '!=', 'draft')]}"/>
                    <button name="action_start_os" string="Iniciar OS"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('os_state', '!=', 'confirmed')]}"/>
                    <button name="action_done_os" string="Concluir OS"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('os_state', '!=', 'in_progress')]}"/>
                    <button name="action_cancel_os" string="Cancelar"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('os_state', 'in', ('done', 'cancel'))]}"/>
                    <field name="os_state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <!-- Cabeçalho da OS -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" string="Número da OS" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Dados da OS">
                            <field name="partner_id" string="Cliente (Razão Social)" required="1"/>
                            <field name="equipment_description" string="Descrição do Equipamento"
                                   placeholder="Ex: Cilindro Hidráulico CH Martelo"/>
                            <field name="deadline_date" string="Prazo"/>
                        </group>
                        <group string="Progresso">
                            <field name="total_components" string="Total de Processos"/>
                            <field name="components_done" string="Concluídos"/>
                            <field name="components_in_progress" string="Em Andamento"/>
                <field name="is_overdue" invisible="1"/>
                            <field name="progress_percent" string="Progresso (%)"
                                   widget="progressbar"/>
                        </group>
                    </group>

                    <!-- Tela 2: Componentes do Cilindro -->
                    <notebook>
                        <page string="Componentes do Cilindro" name="components">
                            <field name="cylinder_component_ids"
                                   context="{'default_repair_id': active_id}">
                                <tree editable="bottom" decoration-success="component_status == 'done'"
                                      decoration-warning="component_status == 'in_progress'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="component_type" string="Tipo"/>
                                    <field name="name" string="Nome / Descrição"/>
                                    <field name="component_status" string="Status" widget="badge"
                                           decoration-success="component_status == 'done'"
                                           decoration-warning="component_status == 'in_progress'"
                                           decoration-muted="component_status == 'pending'"/>
                                    <button name="%(action_repair_component_processes)d"
                                            type="action" string="Ver Processos"
                                            icon="fa-cogs" class="btn-sm btn-info"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_repair_order_os_search" model="ir.ui.view">
        <field name="name">repair.order.os.search</field>
        <field name="model">repair.order</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <search string="Buscar OS">
                <field name="name" string="Nº OS" filter_domain="[('name', 'ilike', self)]"/>
                <field name="partner_id" string="Cliente"/>
                <field name="equipment_description" string="Equipamento"/>
                <separator/>
                <filter name="draft" string="Rascunho" domain="[('os_state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmadas" domain="[('os_state', '=', 'confirmed')]"/>
                <filter name="in_progress" string="Em Andamento" domain="[('os_state', '=', 'in_progress')]"/>
                <filter name="done" string="Concluídas" domain="[('os_state', '=', 'done')]"/>
                <separator/>
                <filter name="overdue" string="Atrasadas"
                        domain="[('deadline_date', '&lt;', context_today().strftime('%Y-%m-%d')),
                                 ('os_state', 'not in', ['done', 'cancel'])]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'os_state'}"/>
                    <filter name="group_deadline" string="Prazo"
                            context="{'group_by': 'deadline_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action principal das OS -->
    <record id="action_repair_orders_os" model="ir.actions.act_window">
        <field name="name">Ordens de Serviço</field>
        <field name="res_model">repair.order</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_repair_order_os_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_repair_order_os_form')})]"/>
        <field name="search_view_id" ref="view_repair_order_os_search"/>
        <field name="context">{'search_default_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nenhuma Ordem de Serviço cadastrada
            </p>
            <p>Clique em Novo para criar a primeira OS.</p>
        </field>
    </record>

</odoo>
