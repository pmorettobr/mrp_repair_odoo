<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
<!-- Sub-componentes pre-cadastrados para cilindros hidraulicos -->
<!-- noupdate="1": so instala uma vez, nao sobrescreve customizacoes -->

    <!-- CAMISA -->
    <record id="sub_camisa_embolo"       model="repair.sub.component"><field name="name">Embolo</field>              <field name="component_type">camisa</field>           <field name="sequence">10</field></record>
    <record id="sub_camisa_haste_int"    model="repair.sub.component"><field name="name">Haste Interna</field>       <field name="component_type">camisa</field>           <field name="sequence">20</field></record>
    <record id="sub_camisa_anel_vedacao" model="repair.sub.component"><field name="name">Anel de Vedacao</field>     <field name="component_type">camisa</field>           <field name="sequence">30</field></record>
    <record id="sub_camisa_flange"       model="repair.sub.component"><field name="name">Flange</field>              <field name="component_type">camisa</field>           <field name="sequence">40</field></record>
    <record id="sub_camisa_pino"         model="repair.sub.component"><field name="name">Pino Guia</field>           <field name="component_type">camisa</field>           <field name="sequence">50</field></record>
    <record id="sub_camisa_bucha"        model="repair.sub.component"><field name="name">Bucha</field>               <field name="component_type">camisa</field>           <field name="sequence">60</field></record>
    <record id="sub_camisa_rosca"        model="repair.sub.component"><field name="name">Rosca</field>               <field name="component_type">camisa</field>           <field name="sequence">70</field></record>
    <record id="sub_camisa_assento"      model="repair.sub.component"><field name="name">Assento</field>             <field name="component_type">camisa</field>           <field name="sequence">80</field></record>

    <!-- HASTE TUBULAR -->
    <record id="sub_haste_pino"          model="repair.sub.component"><field name="name">Pino</field>                <field name="component_type">haste_tubular</field>    <field name="sequence">10</field></record>
    <record id="sub_haste_anel"          model="repair.sub.component"><field name="name">Anel de Vedacao</field>     <field name="component_type">haste_tubular</field>    <field name="sequence">20</field></record>
    <record id="sub_haste_bucha"         model="repair.sub.component"><field name="name">Bucha</field>               <field name="component_type">haste_tubular</field>    <field name="sequence">30</field></record>
    <record id="sub_haste_rosca"         model="repair.sub.component"><field name="name">Rosca</field>               <field name="component_type">haste_tubular</field>    <field name="sequence">40</field></record>
    <record id="sub_haste_diam_ext"      model="repair.sub.component"><field name="name">Diametro Externo</field>    <field name="component_type">haste_tubular</field>    <field name="sequence">50</field></record>
    <record id="sub_haste_diam_int"      model="repair.sub.component"><field name="name">Diametro Interno</field>    <field name="component_type">haste_tubular</field>    <field name="sequence">60</field></record>

    <!-- CABECOTE -->
    <record id="sub_cab_assento_esf"     model="repair.sub.component"><field name="name">Assento Esferico</field>   <field name="component_type">cabecote_traseiro</field><field name="sequence">10</field></record>
    <record id="sub_cab_anel"            model="repair.sub.component"><field name="name">Anel de Vedacao</field>    <field name="component_type">cabecote_traseiro</field><field name="sequence">20</field></record>
    <record id="sub_cab_bucha"           model="repair.sub.component"><field name="name">Bucha Guia</field>         <field name="component_type">cabecote_traseiro</field><field name="sequence">30</field></record>
    <record id="sub_cab_rosca_int"       model="repair.sub.component"><field name="name">Rosca Interna</field>      <field name="component_type">cabecote_traseiro</field><field name="sequence">40</field></record>

    <!-- BLOCO DE VALVULA -->
    <record id="sub_valv_assento"        model="repair.sub.component"><field name="name">Assento da Valvula</field>  <field name="component_type">bloco_valvula</field>    <field name="sequence">10</field></record>
    <record id="sub_valv_eixo"           model="repair.sub.component"><field name="name">Eixo do Bloco</field>      <field name="component_type">bloco_valvula</field>    <field name="sequence">20</field></record>
    <record id="sub_valv_tampa_a"        model="repair.sub.component"><field name="name">Tampa A</field>            <field name="component_type">bloco_valvula</field>    <field name="sequence">30</field></record>
    <record id="sub_valv_tampa_b"        model="repair.sub.component"><field name="name">Tampa B</field>            <field name="component_type">bloco_valvula</field>    <field name="sequence">40</field></record>

    <!-- COMUM A TODOS (component_type = 'todos') -->
    <record id="sub_todos_geral"         model="repair.sub.component"><field name="name">Geral / Todo o componente</field><field name="component_type">todos</field>      <field name="sequence">5</field></record>
    <record id="sub_todos_vedacao"       model="repair.sub.component"><field name="name">Sistema de Vedacao</field>  <field name="component_type">todos</field>            <field name="sequence">10</field></record>
    <record id="sub_todos_superficie"    model="repair.sub.component"><field name="name">Superficie</field>          <field name="component_type">todos</field>            <field name="sequence">20</field></record>

</odoo>
