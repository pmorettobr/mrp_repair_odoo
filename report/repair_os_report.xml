<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_repair_os_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc"/>
            <div class="page">

                <!-- Cabecalho da OS -->
                <div class="row mb-4">
                    <div class="col-8">
                        <h2>OS <t t-esc="doc.name"/> — <t t-esc="doc.equipment_description or ''"/></h2>
                        <p>
                            <strong>Cliente:</strong> <t t-esc="doc.partner_id.name"/><br/>
                            <strong>Prazo:</strong>
                            <t t-esc="doc.deadline_date or '-'"/>
                        </p>
                    </div>
                    <div class="col-4 text-right">
                        <h4>Progresso</h4>
                        <p>
                            <strong><t t-esc="'%.1f' % doc.progress_percent"/>%</strong><br/>
                            <t t-esc="doc.components_done"/> /
                            <t t-esc="doc.total_components"/> processos concluidos
                        </p>
                    </div>
                </div>

                <!-- Um bloco por componente -->
                <t t-foreach="doc.cylinder_component_ids" t-as="comp">
                    <h4 class="mt-3">
                        <t t-esc="comp.name"/>
                        <small class="ml-2" style="font-size:11px;color:#555;">
                            (<t t-esc="dict(comp._fields['component_status'].selection).get(comp.component_status)"/>)
                        </small>
                    </h4>
                    <table class="table table-sm table-bordered" style="font-size:11px;">
                        <thead class="thead-light">
                            <tr>
                                <!-- 3 colunas de identificacao -->
                                <th style="width:14%">Componente</th>
                                <th style="width:14%">Sub-componente</th>
                                <th style="width:14%">Servico</th>
                                <!-- execucao -->
                                <th style="width:12%">Maquina</th>
                                <th style="width:8%">Setor</th>
                                <th style="width:8%">Status</th>
                                <th style="width:9%">Inicio</th>
                                <th style="width:9%">Fim</th>
                                <th style="width:6%">Horas</th>
                                <th style="width:6%">Desvio</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="comp.process_ids" t-as="proc">
                                <tr t-att-style="
                                    'background:#eafaf2;' if proc.status == 'done'
                                    else 'background:#fffbeb;' if proc.status == 'in_progress'
                                    else 'background:#fff0f0;' if proc.status == 'deviation'
                                    else ''">
                                    <!-- Coluna 1: Componente -->
                                    <td><t t-esc="proc.component_id.name or '-'"/></td>
                                    <!-- Coluna 2: Sub-componente -->
                                    <td>
                                        <t t-if="proc.sub_component_id">
                                            <t t-esc="proc.sub_component_id.name"/>
                                        </t>
                                        <t t-elif="proc.sub_component_name">
                                            <t t-esc="proc.sub_component_name"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <!-- Coluna 3: Servico -->
                                    <td><t t-esc="proc.service_name or '-'"/></td>
                                    <!-- Execucao -->
                                    <td>
                                        <t t-if="proc.workcenter_id">
                                            <t t-esc="proc.workcenter_id.name"/>
                                            <t t-if="proc.machine_code">
                                                (<t t-esc="proc.machine_code"/>)
                                            </t>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td><t t-esc="proc.department or '—'"/></td>
                                    <td>
                                        <t t-esc="dict(proc._fields['status'].selection).get(proc.status)"/>
                                    </td>
                                    <td>
                                        <t t-if="proc.time_start">
                                            <t t-esc="proc.time_start.strftime('%d/%m %H:%M')"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td>
                                        <t t-if="proc.time_end">
                                            <t t-esc="proc.time_end.strftime('%d/%m %H:%M')"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td>
                                        <t t-if="proc.duration_hours">
                                            <t t-esc="'%.2f' % proc.duration_hours"/>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td>
                                        <t t-if="proc.has_deviation">
                                            &#9888; <t t-esc="proc.deviation_description or ''"/>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>

            </div>
        </t>
    </template>

    <template id="report_repair_os">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="mrp_repair_odoo.report_repair_os_document"
                   t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

    <report id="action_report_repair_os"
            string="Programacao da OS"
            model="repair.order"
            report_type="qweb-pdf"
            name="mrp_repair_odoo.report_repair_os"
            file="mrp_repair_odoo.report_repair_os"
            print_report_name="'OS-%s' % object.name"/>

</odoo>
